{
  "name": "@upmarto/sdk",
  "version": "0.1.0",
  "description": "Upmarto TypeScript SDK — v1 API client for browser and Node.js",
  "license": "MIT",
  "author": "Upmarto Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mertcaliskanlinux/upmarto.git",
    "directory": "agent-blackbox/upmarto-sdk-ts"
  },

# Bind address (0.0.0.0 = all interfaces; 127.0.0.1 = local only)
APP_HOST=127.0.0.1

# 0 = OS-assigned free port (recommended for dev); set explicit port for production
APP_PORT=0

# Storage paths (relative to working directory or absolute)
DATABASE_PATH=./data/events.log
SQLITE_PATH=./data/metadata.db

# Legacy: parent data directory when paths above are not set
DATA_DIR=./data

# Public URL returned by GET /config (set behind reverse proxy / ingress)
# PUBLIC_BASE_URL=https://blackbox.example.com

TEST_MODE=false

# Legacy aliases (still supported): HOST, PORT, EVENTS_LOG_PATH

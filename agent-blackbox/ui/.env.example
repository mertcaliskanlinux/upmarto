# Build-time API URL (production or direct backend access).
# Leave empty to use same-origin + GET /config runtime discovery.
VITE_API_BASE_URL=

# Dev only: Vite proxy target (backend URL printed on `cargo run` startup).
# Example after backend starts: VITE_API_PROXY_TARGET=http://127.0.0.1:54321
VITE_API_PROXY_TARGET=

# Dev server port (optional; Vite picks a free port if unset)
# VITE_DEV_PORT=5173

VITE_DEFAULT_PROJECT_ID=agent-blackbox

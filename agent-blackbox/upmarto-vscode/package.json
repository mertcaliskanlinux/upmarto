{
  "name": "upmarto-vscode",
  "displayName": "Upmarto",
  "description": "Local-first AI agent debugger — capture sessions, replay timelines, and explain root causes without the cloud.",
  "version": "0.1.1",
  "publisher": "upmarto",
  "license": "MIT",
  "author": "Upmarto Contributors",
  "icon": "media/icon-128.png",
  "galleryBanner": {
    "color": "#1B1F3B",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mertcaliskanlinux/upmarto.git",
    "directory": "agent-blackbox/upmarto-vscode"
  },
  "homepage": "https://github.com/mertcaliskanlinux/upmarto/tree/main/agent-blackbox/upmarto-vscode#readme",
  "bugs": {
    "url": "https://github.com/mertcaliskanlinux/upmarto/issues"
  },
  "keywords": [
    "upmarto",
    "ai-agents",
    "copilot",
    "cursor",
    "debugging",
    "timeline",
    "explain",
    "root-cause",
    "event-capture",
    "local-first"
  ],
  "type": "module",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Upmarto",
      "properties": {
        "upmarto.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable passive event capture to Upmarto (uses .upmarto/config.json via SDK)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "build": "npm run compile",
    "watch": "tsc -p . --watch",
    "prepublishOnly": "npm run compile"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@upmarto/sdk": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.0"
  },
  "upmarto": {
    "registrySdkVersion": "^0.1.0",
    "localSdkPath": "file:../upmarto-sdk-ts",
    "publishNote": "Run: node ../scripts/set-sdk-dependency.mjs registry (see docs/PUBLISHING.md)"
  }
}
